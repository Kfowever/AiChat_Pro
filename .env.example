# AiChat Pro Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_NAME=AiChat Pro
APP_URL=http://localhost
APP_DEBUG=true
APP_ENV=development
APP_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:8080

# JWT Secret (IMPORTANT: Change this to a random string in production!)
JWT_SECRET=change_this_to_a_random_secret_string

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=aichat_pro
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# Upload
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif,webp
UPLOAD_ALLOWED_FILE_TYPES=pdf,txt,md,csv,json,doc,docx

# Chat limits
CHAT_MAX_MESSAGE_CHARS=20000
CHAT_ATTACHMENT_PREVIEW_CHARS=12000

# Rate limits
RATE_LIMIT_API_MAX=120
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_CHAT_MAX=30
RATE_LIMIT_UPLOAD_MAX=10
RATE_LIMIT_ADMIN_MAX=8

# AI API Keys (Fill in your API keys)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# Payment Configuration
# Alipay (支付宝 - Fill in your Alipay credentials)
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# WeChat Pay (微信支付 - Fill in your WeChat Pay credentials)
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=
WECHAT_CERT_PATH=
WECHAT_KEY_PATH=
